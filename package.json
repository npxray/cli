{
  "name": "@npxray/cli",
  "version": "0.4.2",
  "description": "X-ray vision for npx: a deterministic npm package risk profiler and guarded runner.",
  "license": "Apache-2.0",
  "type": "module",
  "author": "npxray contributors",
  "homepage": "https://github.com/npxray/cli#readme",
  "packageManager": "bun@1.3.14",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/npxray/cli.git"
  },
  "bugs": {
    "url": "https://github.com/npxray/cli/issues"
  },
  "keywords": [
    "npm",
    "npx",
    "security",
    "audit",
    "risk",
    "supply-chain",
    "inspect",
    "cli"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "npxray": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/make-bin-executable.mjs",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "fmt": "biome format --write .",
    "fmt:check": "biome format .",
    "test": "bun test test",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@npxray/contracts": "^0.4.5"
  },
  "optionalDependencies": {
    "@npxray/engine-bin-darwin-amd64": "0.4.1",
    "@npxray/engine-bin-darwin-arm64": "0.4.1",
    "@npxray/engine-bin-linux-amd64": "0.4.1",
    "@npxray/engine-bin-linux-arm64": "0.4.1",
    "@npxray/engine-bin-windows-amd64": "0.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@types/bun": "^1.3.6",
    "@types/node": "^24.10.4",
    "typescript": "^5.9.3",
    "tsx": "^4.21.0"
  }
}
